<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <h1 class="h2">Dashboard</h1>
</div>

<div class="row">
  <div class="col-md-3 mb-4">
    <%= link_to admin_products_path, class: "text-decoration-none" do %>
      <div class="card text-bg-primary h-100" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h5 class="card-title">Products</h5>
              <h2><%= Product.count %></h2>
              <small>Click to manage</small>
            </div>
            <div class="align-self-center">
              <i class="bi bi-box fs-1"></i>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  
  <div class="col-md-3 mb-4">
    <%= link_to admin_orders_path, class: "text-decoration-none" do %>
      <div class="card text-bg-success h-100" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h5 class="card-title">Orders</h5>
              <h2><%= Order.count %></h2>
              <small>Click to view</small>
            </div>
            <div class="align-self-center">
              <i class="bi bi-bag fs-1"></i>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  
  <div class="col-md-3 mb-4">
    <%= link_to admin_customers_path, class: "text-decoration-none" do %>
      <div class="card text-bg-info h-100" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
        <div class="card-body">
          <div class="d-flex justify-content-between">
            <div>
              <h5 class="card-title">Customers</h5>
              <h2><%= User.where(is_admin: false).count %></h2>
              <small>Click to view</small>
            </div>
            <div class="align-self-center">
              <i class="bi bi-people fs-1"></i>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  
  <div class="col-md-3 mb-4">
    <div class="card text-bg-warning h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h5 class="card-title">Revenue</h5>
            <h2>$<%= sprintf("%.0f", Order.where(payment_status: 'paid').sum(:total_amount)) %></h2>
            <small>Total sales</small>
          </div>
          <div class="align-self-center">
            <i class="bi bi-currency-dollar fs-1"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row mt-4">
  <div class="col-12">
    <h3>Quick Actions</h3>
    <div class="d-flex gap-2 mb-4 flex-wrap">
      <%= link_to admin_products_path, class: "btn btn-primary" do %>
        <i class="bi bi-box me-2"></i>Manage Products
      <% end %>
      <%= link_to new_admin_product_path, class: "btn btn-success" do %>
        <i class="bi bi-plus-circle me-2"></i>Add New Product
      <% end %>
      <%= link_to admin_categories_path, class: "btn btn-outline-secondary" do %>
        <i class="bi bi-tags me-2"></i>Manage Categories
      <% end %>
      <%= link_to admin_orders_path, class: "btn btn-outline-info" do %>
        <i class="bi bi-bag me-2"></i>View Orders
      <% end %>
      <%= link_to admin_reviews_path, class: "btn btn-outline-warning" do %>
        <i class="bi bi-star me-2"></i>Customer Reviews
      <% end %>
    </div>
  </div>
</div>