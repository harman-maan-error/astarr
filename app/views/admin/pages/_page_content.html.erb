<article class="page-article">
  <header class="page-header">
    <h1><%= page.title %></h1>
  </header>
  
  <div class="page-body">
    <%= raw page.content %>
  </div>
  
  <footer class="page-footer">
    <p class="last-updated">
      Last updated: <%= page.updated_at.strftime("%B %d, %Y") %>
    </p>
  </footer>
</article>