<!-- app/views/admin/products/new.html.erb -->
<div class="admin-header">
  <h1>Add New Product</h1>
  <%= link_to "← Back to Products", admin_products_path, class: "btn btn-secondary" %>
</div>

<div class="admin-content">
  <%= form_with model: [:admin, @product], local: true, class: "admin-form" do |form| %>
    <% if @product.errors.any? %>
      <div class="alert alert-danger">
        <h4><%= pluralize(@product.errors.count, "error") %> prohibited this product from being saved:</h4>
        <ul>
          <% @product.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control", placeholder: "Enter product name" %>
    </div>

    <div class="form-group">
      <%= form.label :slug, "URL Slug", class: "form-label" %>
      <%= form.text_field :slug, class: "form-control", placeholder: "product-name (will be auto-generated if left blank)" %>
      <small class="form-text text-muted">Used in the product URL. Leave blank to auto-generate from name.</small>
    </div>

    <div class="form-group">
      <%= form.label :base_price, "Price", class: "form-label" %>
      <%= form.number_field :base_price, step: 0.01, min: 0, class: "form-control", placeholder: "0.00" %>
    </div>

    <div class="form-group">
      <%= form.label :stock_quantity, "Stock Quantity", class: "form-label" %>
      <%= form.number_field :stock_quantity, min: 0, class: "form-control", placeholder: "0" %>
    </div>

    <div class="form-group">
      <%= form.label :iphone_model, "iPhone Model", class: "form-label" %>
      <%= form.select :iphone_model, 
          options_for_select(Product::IPHONE_MODELS.map { |model| [model, model] }), 
          { prompt: 'Select iPhone Model' }, 
          { class: "form-control" } %>
    </div>

    <div class="form-group">
      <%= form.label :color, "Color", class: "form-label" %>
      <%= form.select :color, 
          options_for_select([
            ['Black', 'black'],
            ['White', 'white'],
            ['Clear', 'clear'],
            ['Blue', 'blue'],
            ['Pink', 'pink'],
            ['Purple', 'purple'],
            ['Green', 'green'],
            ['Red', 'red'],
            ['Gold', 'gold'],
            ['Silver', 'silver'],
            ['Space Gray', 'space_gray'],
            ['Rose Gold', 'rose_gold']
          ]), 
          { prompt: 'Select Color' }, 
          { class: "form-control" } %>
    </div>

    <div class="form-group">
      <%= form.label :material, "Material", class: "form-label" %>
      <%= form.select :material, 
          options_for_select([
            ['Silicone', 'silicone'],
            ['TPU', 'tpu'],
            ['Hard Plastic', 'hard_plastic'],
            ['Leather', 'leather'],
            ['Metal', 'metal'],
            ['Glass', 'glass'],
            ['Carbon Fiber', 'carbon_fiber'],
            ['Hybrid', 'hybrid']
          ]), 
          { prompt: 'Select Material' }, 
          { class: "form-control" } %>
    </div>

    <div class="form-group">
      <%= form.label :category_id, "Category", class: "form-label" %>
      <%= form.select :category_id, 
          options_for_select([
            ['Astarr', 1],
            ['Astarr Premium', 2]
          ]), 
          { prompt: 'Select Category' }, 
          { class: "form-control" } %>
    </div>

    <div class="form-group">
      <%= form.label :description, "Description (optional)", class: "form-label" %>
      <%= form.text_area :description, rows: 3, class: "form-control", placeholder: "Enter product description" %>
    </div>

    <div class="form-group">
      <%= form.label :specifications, "Specifications (optional)", class: "form-label" %>
      <%= form.text_area :specifications, rows: 3, class: "form-control", placeholder: "Enter product specifications" %>
    </div>

    <!-- Sale and Featured Options -->
    <div class="form-row">
      <div class="form-group col-md-6">
        <%= form.check_box :is_featured, class: "form-check-input" %>
        <%= form.label :is_featured, "Featured Product", class: "form-check-label" %>
        <small class="form-text text-muted">Display this product in featured sections</small>
      </div>
      
      <div class="form-group col-md-6">
        <%= form.check_box :is_on_sale, class: "form-check-input", onchange: "toggleSalePrice()" %>
        <%= form.label :is_on_sale, "On Sale", class: "form-check-label" %>
        <small class="form-text text-muted">Mark this product as on sale</small>
      </div>
    </div>

    <div class="form-group" id="sale-price-group" style="display: none;">
      <%= form.label :sale_price, "Sale Price", class: "form-label" %>
      <%= form.number_field :sale_price, step: 0.01, min: 0, class: "form-control", placeholder: "0.00" %>
      <small class="form-text text-muted">Sale price (must be lower than base price)</small>
    </div>

    <div class="form-group">
      <%= form.check_box :active, { checked: true }, class: "form-check-input" %>
      <%= form.label :active, "Make product active (visible in store)", class: "form-check-label" %>
    </div>

    <!-- Updated Image Upload Section -->
    <div class="form-group">
      <%= form.label :images, "Product Images", class: "form-label" %>
      <%= form.file_field :images, class: "form-control", accept: "image/*", multiple: true, onchange: "previewImages(this)" %>
      <small class="form-text text-muted">Upload multiple product images (JPG, PNG, GIF). First image will be the primary image.</small>
      <div id="images-preview" class="images-preview"></div>
    </div>

    <div class="form-actions">
      <%= form.submit "Create Product", class: "btn btn-primary" %>
      <%= link_to "Cancel", admin_products_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<style>
  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 1px solid #dee2e6;
  }

  .admin-content {
    max-width: 800px;
  }

  .admin-form {
    background: #f8f9fa;
    padding: 30px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-label {
    font-weight: 600;
    margin-bottom: 8px;
    color: #495057;
    display: block;
  }

  .form-control {
    width: 100%;
    padding: 10px 15px;
    border: 1px solid #ced4da;
    border-radius: 4px;
    font-size: 16px;
  }

  .form-control:focus {
    border-color: #007bff;
    outline: 0;
    box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
  }

  .form-actions {
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid #dee2e6;
  }

  .btn {
    padding: 10px 20px;
    border: none;
    border-radius: 4px;
    font-size: 16px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    margin-right: 10px;
  }

  .btn-primary {
    background-color: #007bff;
    color: white;
  }

  .btn-secondary {
    background-color: #6c757d;
    color: white;
  }

  .btn:hover {
    opacity: 0.9;
  }

  .alert {
    padding: 15px;
    margin-bottom: 20px;
    border-radius: 4px;
  }

  .alert-danger {
    background-color: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
  }

  .form-text {
    font-size: 14px;
    color: #6c757d;
  }

  .form-row {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
  }

  .form-row .form-group {
    flex: 1;
    margin-bottom: 0;
  }

  .form-check-input {
    margin-right: 8px;
  }

  .form-check-label {
    font-weight: 600;
    color: #495057;
  }

  /* Updated image preview styles */
  .images-preview {
    margin-top: 15px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .image-preview-item {
    position: relative;
    display: inline-block;
  }

  .image-preview-item img {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border: 2px solid #ddd;
    border-radius: 4px;
  }

  .image-preview-item.primary {
    border: 2px solid #007bff;
  }

  .image-preview-item.primary::after {
    content: "PRIMARY";
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    background: #007bff;
    color: white;
    padding: 2px 8px;
    font-size: 10px;
    border-radius: 4px;
    font-weight: bold;
  }

  .remove-image {
    position: absolute;
    top: -8px;
    right: -8px;
    background: #dc3545;
    color: white;
    border: none;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    font-size: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

<script>
  function previewImages(input) {
    const preview = document.getElementById('images-preview');
    preview.innerHTML = '';
    
    if (input.files) {
      Array.from(input.files).forEach((file, index) => {
        if (file.type.startsWith('image/')) {
          const reader = new FileReader();
          
          reader.onload = function(e) {
            const div = document.createElement('div');
            div.className = `image-preview-item ${index === 0 ? 'primary' : ''}`;
            
            div.innerHTML = `
              <img src="${e.target.result}" alt="Preview ${index + 1}">
              <button type="button" class="remove-image" onclick="removePreviewImage(this, ${index})">&times;</button>
            `;
            
            preview.appendChild(div);
          };
          
          reader.readAsDataURL(file);
        }
      });
    }
  }

  function removePreviewImage(button, index) {
    // Remove the preview
    button.parentElement.remove();
    
    // Note: Removing from actual file input is complex
    // For now, just hide the preview. The user can re-select files.
    console.log(`Would remove image at index ${index}`);
  }

  function toggleSalePrice() {
    const checkbox = document.querySelector('input[name="product[is_on_sale]"]');
    const salePriceGroup = document.getElementById('sale-price-group');
    const salePriceInput = document.querySelector('input[name="product[sale_price]"]');
    
    if (checkbox.checked) {
      salePriceGroup.style.display = 'block';
      salePriceInput.required = true;
    } else {
      salePriceGroup.style.display = 'none';
      salePriceInput.required = false;
      salePriceInput.value = '';
    }
  }

  // Initialize sale price visibility on page load
  document.addEventListener('DOMContentLoaded', function() {
    toggleSalePrice();
  });
</script>