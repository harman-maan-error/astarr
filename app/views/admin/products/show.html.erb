<!-- app/views/admin/products/show.html.erb -->
<div class="admin-header">
  <h1>Product Details</h1>
  <div>
    <%= link_to "← Back to Products", "/admin/products", class: "btn btn-secondary" %>
    <%= link_to "Edit Product", "/admin/products/#{@product.id}/edit", class: "btn btn-primary" %>
  </div>
</div>

<div class="admin-content">
  <div class="product-details">
    <div class="detail-row">
      <strong>ID:</strong>
      <span><%= @product.id %></span>
    </div>

    <div class="detail-row">
      <strong>Name:</strong>
      <span><%= @product.name %></span>
    </div>

    <div class="detail-row">
      <strong>iPhone Model:</strong>
      <span><%= @product.iphone_model %></span>
    </div>

    <div class="detail-row">
      <strong>Category:</strong>
      <span><%= @product.category&.name %></span>
    </div>

    <div class="detail-row">
      <strong>Price:</strong>
      <span>$<%= @product.base_price %></span>
    </div>

    <div class="detail-row">
      <strong>Stock Quantity:</strong>
      <span><%= @product.stock_quantity %></span>
    </div>

    <% if @product.description.present? %>
      <div class="detail-row">
        <strong>Description:</strong>
        <span><%= @product.description %></span>
      </div>
    <% end %>

    <div class="detail-row">
      <strong>Created:</strong>
      <span><%= @product.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
    </div>

    <div class="detail-row">
      <strong>Last Updated:</strong>
      <span><%= @product.updated_at.strftime("%B %d, %Y at %I:%M %p") %></span>
    </div>
  </div>

  <div class="actions-section">
    <%= link_to "Edit Product", "/admin/products/#{@product.id}/edit", class: "btn btn-primary" %>
    <%= form_with url: "/admin/products/#{@product.id}", method: :delete, local: true, style: "display: inline-block;" do |form| %>
      <%= form.submit "Delete Product", 
          class: "btn btn-danger", 
          data: { confirm: "Are you sure you want to delete this product? This action cannot be undone." } %>
    <% end %>
  </div>
</div>

<style>
  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 1px solid #dee2e6;
  }

  .admin-content {
    max-width: 800px;
  }

  .product-details {
    background: #f8f9fa;
    padding: 30px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
    margin-bottom: 30px;
  }

  .detail-row {
    display: flex;
    margin-bottom: 15px;
    align-items: flex-start;
  }

  .detail-row strong {
    min-width: 150px;
    color: #495057;
    font-weight: 600;
  }

  .detail-row span {
    flex: 1;
    color: #212529;
  }

  .actions-section {
    padding: 20px;
    background: white;
    border-radius: 8px;
    border: 1px solid #dee2e6;
    text-align: center;
  }

  .btn {
    padding: 10px 20px;
    border: none;
    border-radius: 4px;
    font-size: 16px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    margin: 0 10px;
  }

  .btn-primary {
    background-color: #007bff;
    color: white;
  }

  .btn-secondary {
    background-color: #6c757d;
    color: white;
  }

  .btn-danger {
    background-color: #dc3545;
    color: white;
  }

  .btn:hover {
    opacity: 0.9;
    text-decoration: none;
  }
</style>