<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-semibold text-gray-900">Customers</h1>
            <p class="mt-1 text-sm text-gray-500">Manage customer accounts and outstanding orders</p>
          </div>
          <div class="flex space-x-3">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-blue-500">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Total Customers</h3>
        <p class="text-3xl font-bold text-gray-900 mt-2"><%= @customers.count %></p>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-orange-500">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Outstanding Orders</h3>
        <p class="text-3xl font-bold text-orange-600 mt-2"><%= @total_outstanding %></p>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-green-500">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Outstanding Value</h3>
        <p class="text-3xl font-bold text-green-600 mt-2">$<%= number_with_precision(@outstanding_value, precision: 2) %></p>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-purple-500">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Active Customers</h3>
        <p class="text-3xl font-bold text-purple-600 mt-2"><%= @customers_with_outstanding %></p>
      </div>
    </div>

    <!-- Main Content -->
    <div class="bg-white shadow-sm rounded-lg">
      <!-- Table Header -->
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-medium text-gray-900">All Customers</h2>
        </div>
      </div>

      <!-- Table -->
      <div class="overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Customer</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contact & Location</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total Orders</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Outstanding</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @customers.each do |customer| %>
              <% outstanding_orders = customer.orders.where(status: ['pending', 'processing', 'shipped']) %>
              <tr class="hover:bg-gray-50">
                <!-- Customer Info -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="h-10 w-10 rounded-full bg-gray-600 flex items-center justify-center text-white font-medium text-sm">
                      <%= customer.first_name&.first&.upcase %><%= customer.last_name&.first&.upcase %>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900">
                        <%= customer.full_name %>
                      </div>
                      <div class="text-sm text-gray-500">
                        Member since <%= customer.created_at.strftime("%b %Y") %>
                      </div>
                    </div>
                  </div>
                </td>

                <!-- Contact Info & Location -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900"><%= customer.email %></div>
                  <% if customer.phone.present? %>
                    <div class="text-sm text-gray-500"><%= customer.phone %></div>
                  <% else %>
                    <div class="text-sm text-gray-400">No phone</div>
                  <% end %>
                  <% if customer.default_address&.province.present? %>
                    <div class="text-sm text-blue-600 font-medium"><%= customer.default_address.province %></div>
                  <% else %>
                    <div class="text-sm text-gray-400">No province</div>
                  <% end %>
                </td>

                <!-- Order Stats -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900">
                    <%= customer.orders.count %> orders
                  </div>
                  <div class="text-sm text-gray-500">
                    $<%= number_with_precision(customer.orders.sum(:total_amount) || 0, precision: 2) %> spent
                  </div>
                </td>

                <!-- Outstanding Orders -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if outstanding_orders.any? %>
                    <div class="text-sm font-medium text-red-600">
                      <%= outstanding_orders.count %> orders
                    </div>
                    <div class="text-sm text-gray-500">
                      $<%= number_with_precision(outstanding_orders.sum(:total_amount), precision: 2) %>
                    </div>
                  <% else %>
                    <div class="text-sm text-green-600 font-medium">All clear</div>
                  <% end %>
                </td>

                <!-- Status -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if outstanding_orders.any? %>
                    <span class="inline-flex px-3 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">
                      Has Outstanding
                    </span>
                  <% else %>
                    <span class="inline-flex px-3 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                      Up to Date
                    </span>
                  <% end %>
                </td>

                <!-- Actions -->
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-3">
                    <%= link_to "View Details", admin_customer_path(customer), 
                        class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                  </div>
                </td>
              </tr>

              <!-- Outstanding Orders Details Row -->
              <% if outstanding_orders.any? %>
                <tr class="bg-red-25">
                  <td colspan="6" class="px-6 py-4 bg-red-50">
                    <div class="border-l-4 border-red-200 pl-4">
                      <h4 class="font-medium text-gray-900 mb-3">Outstanding Orders:</h4>
                      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <% outstanding_orders.limit(3).each do |order| %>
                          <div class="bg-white border border-gray-200 rounded p-4">
                            <div class="flex justify-between items-start mb-2">
                              <%= link_to admin_order_path(order.order_number), 
                                  class: "font-medium text-indigo-600 hover:text-indigo-800" do %>
                                Order #<%= order.order_number %>
                              <% end %>
                              <span class="px-2 py-1 text-xs font-medium rounded 
                                         <%= case order.status
                                             when 'pending' then 'bg-yellow-100 text-yellow-800'
                                             when 'processing' then 'bg-blue-100 text-blue-800'  
                                             when 'shipped' then 'bg-purple-100 text-purple-800'
                                             else 'bg-gray-100 text-gray-800'
                                             end %>">
                                <%= order.status.titleize %>
                              </span>
                            </div>
                            <div class="text-sm space-y-1">
                              <p class="font-medium text-gray-900">
                                $<%= number_with_precision(order.total_amount, precision: 2) %>
                              </p>
                              <p class="text-gray-500">
                                <%= pluralize(order.order_items.sum(:quantity), 'item') %>
                              </p>
                              <p class="text-gray-500">
                                Ordered: <%= order.created_at.strftime("%b %d, %Y") %>
                              </p>
                              <% if order.shipped_at.present? %>
                                <p class="text-purple-600 font-medium">
                                  Shipped: <%= order.shipped_at.strftime("%b %d, %Y") %>
                                </p>
                              <% end %>
                            </div>
                          </div>
                        <% end %>
                        <% if outstanding_orders.count > 3 %>
                          <div class="bg-gray-100 border border-gray-200 rounded p-4 flex items-center justify-center">
                            <span class="text-sm text-gray-600 font-medium">
                              +<%= outstanding_orders.count - 3 %> more orders
                            </span>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Empty State -->
      <% if @customers.empty? %>
        <div class="text-center py-16">
          <h3 class="text-lg font-medium text-gray-900">No customers found</h3>
          <p class="mt-2 text-sm text-gray-500">Get started by having customers sign up for your store.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>