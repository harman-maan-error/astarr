<% content_for :title, "Shopping Cart" %>

<div class="container py-4">
  <h1>Shopping Cart</h1>

  <% if current_cart.empty? %>
    <div class="text-center py-5">
      <i class="bi bi-bag display-1 text-muted"></i>
      <h3 class="mt-3">Your cart is empty</h3>
      <p class="text-muted">Start shopping to add items to your cart.</p>
      <%= link_to "Shop Now", products_path, class: "btn btn-primary" %>
    </div>
  <% else %>
    <div class="row">
      <div class="col-lg-8">
        <% @cart_products.each do |product| %>
          <% quantity = @cart_items[product.id.to_s] %>
          <div class="card mb-3">
            <div class="row g-0">
              <div class="col-md-3">
                <% if product.primary_image&.image&.attached? %>
                  <%= image_tag product.primary_image.image, class: "img-fluid rounded-start h-100", style: "object-fit: cover;" %>
                <% else %>
                  <div class="bg-light h-100 d-flex align-items-center justify-content-center">
                    <i class="bi bi-phone display-4 text-muted"></i>
                  </div>
                <% end %>
              </div>
              <div class="col-md-9">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <h5 class="card-title">
                        <%= link_to product.name, product, class: "text-decoration-none" %>
                      </h5>
                      <p class="text-muted"><%= product.iphone_model %> • <%= product.color %></p>
                      <% if product.category.is_premium? %>
                        <span class="badge bg-warning text-dark mb-2">Premium</span>
                      <% end %>
                      <p class="fw-bold">
                        $<%= sprintf("%.2f", product.current_price) %>
                        <% if product.is_on_sale? %>
                          <span class="badge bg-danger ms-2">Sale</span>
                        <% end %>
                      </p>
                      <p class="small text-muted">Subtotal: $<%= sprintf("%.2f", product.current_price * quantity) %></p>
                    </div>
                    <div class="d-flex align-items-center">
                      <%= form_with url: update_cart_item_path(product.slug), method: :patch, local: true, class: "d-flex align-items-center me-3" do |f| %>
                        <div class="input-group input-group-sm" style="width: 120px;">
                          <%= f.number_field :quantity, value: quantity, min: 1, max: 10, class: "form-control" %>
                          <button class="btn btn-outline-primary" type="submit">
                            <i class="bi bi-arrow-clockwise"></i>
                          </button>
                        </div>
                      <% end %>
                      <%= button_to remove_from_cart_path(product.slug), method: :delete, 
                                    class: "btn btn-outline-danger btn-sm", 
                                    confirm: "Remove #{product.name} from cart?",
                                    form: { style: "display: inline;" } do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="mt-3 d-flex justify-content-between align-items-center">
          <%= link_to products_path, class: "btn btn-outline-primary" do %>
            <i class="bi bi-arrow-left"></i> Continue Shopping
          <% end %>

          <%= button_to clear_cart_path, method: :delete, 
                        class: "btn btn-outline-danger", 
                        confirm: "Are you sure you want to clear your entire cart?",
                        form: { style: "display: inline;" } do %>
            <i class="bi bi-trash"></i> Clear Cart
          <% end %>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card sticky-top" style="top: 20px;">
          <div class="card-header">
            <h5 class="card-title mb-0">Order Summary</h5>
          </div>
          <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
              <span>Items in cart:</span>
              <span><%= current_cart.total_items %></span>
            </div>

            <div class="d-flex justify-content-between mb-2">
              <span>Subtotal:</span>
              <span class="fw-bold">$<%= sprintf("%.2f", current_cart.subtotal) %></span>
            </div>

            <hr>

            <div class="d-flex justify-content-between mb-3">
              <span>Estimated Tax:</span>
              <span class="text-muted">Calculated at checkout</span>
            </div>

            <div class="d-flex justify-content-between mb-3 fs-5">
              <span class="fw-bold">Total:</span>
              <span class="fw-bold">$<%= sprintf("%.2f", current_cart.subtotal) %></span>
            </div>

            <div class="d-grid gap-2">
              <% if logged_in? %>
                <button class="btn btn-success btn-lg" onclick="placeOrder()" type="button">
                  <i class="bi bi-bag-check"></i> Place Order
                </button>
                <div id="order-status" class="text-success mt-2 fw-bold text-center" style="display: none;">
                  ✅ Order placed!
                </div>
              <% else %>
                <%= link_to login_path, class: "btn btn-primary btn-lg" do %>
                  <i class="bi bi-person"></i> Login to Checkout
                <% end %>
                <small class="text-center text-muted mt-2">
                  Don't have an account? <%= link_to "Sign up", signup_path %>
                </small>
              <% end %>
            </div>

            <div class="text-center mt-3">
              <small class="text-muted">
                <i class="bi bi-shield-check"></i> Secure checkout with SSL encryption
              </small>
            </div>
          </div>
        </div>

        <!-- Security & Shipping Info -->
        <div class="card mt-3">
          <div class="card-body">
            <h6 class="card-title">Why shop with Astarr?</h6>
            <ul class="list-unstyled small">
              <li class="mb-2">
                <i class="bi bi-truck text-primary me-2"></i>
                Free shipping on orders over $50
              </li>
              <li class="mb-2">
                <i class="bi bi-arrow-counterclockwise text-primary me-2"></i>
                30-day return policy
              </li>
              <li class="mb-2">
                <i class="bi bi-shield-check text-primary me-2"></i>
                Lifetime warranty on Premium cases
              </li>
              <li class="mb-0">
                <i class="bi bi-headset text-primary me-2"></i>
                24/7 customer support
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  function placeOrder() {
    const statusDiv = document.getElementById("order-status");
    statusDiv.style.display = "block";

    // Optional: Disable the button after placing order
    const button = document.querySelector("button[onclick='placeOrder()']");
    button.disabled = true;
    button.innerHTML = '<i class="bi bi-check2-circle"></i> Order Placed';
  }
</script>
