<% content_for :title, "Login" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
      <div class="card shadow">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <i class="bi bi-phone display-4 text-primary"></i>
            <h2 class="card-title mt-3">Login to Astarr</h2>
            <p class="text-muted">Welcome back! Please sign in to your account</p>
          </div>
          
          <%= form_with url: login_path, method: :post, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, class: "form-control", required: true, placeholder: "your@email.com" %>
            </div>
            
            <div class="mb-3">
              <%= f.label :password, class: "form-label" %>
              <%= f.password_field :password, class: "form-control", required: true, placeholder: "Enter your password" %>
            </div>
            
            <div class="d-grid">
              <%= f.submit "Login", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
          
          <hr class="my-4">
          
          <div class="text-center">
            <p class="mb-2">Don't have an account?</p>
            <%= link_to "Create Account", signup_path, class: "btn btn-outline-primary w-100" %>
          </div>
          
          <div class="text-center mt-4">
            <small class="text-muted">
              <strong>Demo Accounts:</strong><br>
              Admin: admin@astarr.com / admin123<br>
              Customer: john.doe@example.com / password123
            </small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>