<% content_for :title, @product.name %>
<% content_for :description, @product.description %>

<div class="container py-4">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
      <li class="breadcrumb-item"><%= link_to @product.category.name, products_path(category: @product.category.slug) %></li>
      <li class="breadcrumb-item active"><%= @product.name %></li>
    </ol>
  </nav>
  
  <div class="row">
    <!-- Product Images -->
    <div class="col-lg-6 mb-4">
      <% if @product.product_images.any? %>
        <div id="productCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <% @product.product_images.ordered.each_with_index do |image, index| %>
              <div class="carousel-item <%= 'active' if index == 0 %>">
                <%= image_tag image.image, class: "d-block w-100 rounded", style: "height: 400px; object-fit: cover;" %>
              </div>
            <% end %>
          </div>
          <% if @product.product_images.count > 1 %>
            <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
              <span class="carousel-control-next-icon"></span>
            </button>
          <% end %>
        </div>
        
        <!-- Thumbnail Navigation -->
        <% if @product.product_images.count > 1 %>
          <div class="d-flex gap-2 mt-3">
            <% @product.product_images.ordered.each_with_index do |image, index| %>
              <button type="button" data-bs-target="#productCarousel" data-bs-slide-to="<%= index %>" 
                      class="border-0 <%= 'active' if index == 0 %>" style="width: 60px; height: 60px;">
                <%= image_tag image.image, class: "img-fluid rounded", style: "width: 100%; height: 100%; object-fit: cover;" %>
              </button>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 400px;">
          <div class="text-center">
            <i class="bi bi-phone display-1 text-muted"></i>
            <p class="text-muted mt-3">No image available</p>
          </div>
        </div>
      <% end %>
    </div>
    
    <!-- Product Details -->
    <div class="col-lg-6">
      <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
          <h1 class="mb-2"><%= @product.name %></h1>
          <p class="text-muted mb-0">for <%= @product.iphone_model %></p>
        </div>
        <% if @product.category.is_premium? %>
          <span class="badge bg-warning text-dark fs-6">Premium</span>
        <% end %>
      </div>
      
      <!-- Rating -->
      <div class="d-flex align-items-center mb-3">
        <% if @product.average_rating.present? && @product.average_rating > 0 %>
          <div class="me-3">
            <% 5.times do |i| %>
              <% if i < @product.average_rating.floor %>
                <i class="bi bi-star-fill text-warning"></i>
              <% elsif i < @product.average_rating %>
                <i class="bi bi-star-half text-warning"></i>
              <% else %>
                <i class="bi bi-star text-muted"></i>
              <% end %>
            <% end %>
            <span class="ms-2"><%= @product.average_rating %></span>
          </div>
          <small class="text-muted">(<%= @product.reviews_count || 0 %> reviews)</small>
        <% else %>
          <small class="text-muted">No reviews yet</small>
        <% end %>
      </div>
      
      <!-- Price -->
      <div class="mb-4">
        <% if @product.is_on_sale? && @product.sale_price.present? %>
          <span class="text-decoration-line-through text-muted fs-5">$<%= sprintf("%.2f", @product.calculated_price) %></span>
          <span class="fs-3 fw-bold text-danger ms-2">$<%= sprintf("%.2f", @product.sale_price) %></span>
          <span class="badge bg-danger ms-2">Sale</span>
        <% else %>
          <span class="fs-3 fw-bold">$<%= sprintf("%.2f", @product.current_price) %></span>
        <% end %>
      </div>
      
      <!-- Product Info -->
      <div class="row mb-4">
        <div class="col-6">
          <strong>Color:</strong> <%= @product.color %>
        </div>
        <div class="col-6">
          <strong>Material:</strong> <%= @product.material %>
        </div>
      </div>
      
      <!-- Add to Cart -->
      <div class="mb-4">
        <% if @product.in_stock? %>
          <%= form_with url: add_to_cart_path(@product), method: :post, local: true do |f| %>
            <div class="row align-items-end">
              <div class="col-4">
                <%= f.label :quantity, "Quantity", class: "form-label" %>
                <%= f.number_field :quantity, value: 1, min: 1, max: [@product.stock_quantity, 10].min, class: "form-control" %>
              </div>
              <div class="col-8">
                <%= f.submit "Add to Cart", class: "btn btn-primary btn-lg w-100" %>
              </div>
            </div>
          <% end %>
          <p class="small text-muted mt-2"><%= @product.stock_quantity %> in stock</p>
        <% else %>
          <button class="btn btn-secondary btn-lg w-100" disabled>Out of Stock</button>
          <p class="small text-muted mt-2">This item is currently out of stock</p>
        <% end %>
      </div>
      
      <!-- Description -->
      <div class="mb-4">
        <h5>Description</h5>
        <p><%= @product.description %></p>
      </div>
      
      <!-- Specifications -->
      <% if @product.specifications.present? %>
        <div class="mb-4">
          <h5>Specifications</h5>
          <p><%= @product.specifications %></p>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Reviews Section -->
  <div class="row mt-5">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Customer Reviews</h3>
        <% if logged_in? %>
          <%= link_to "Write a Review", new_product_review_path(@product), class: "btn btn-outline-primary" %>
        <% else %>
          <%= link_to "Login to Write a Review", login_path, class: "btn btn-outline-primary" %>
        <% end %>
      </div>
      
      <% if @reviews.any? %>
        <% @reviews.each do |review| %>
          <div class="card mb-3">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <h6 class="mb-1"><%= review.title %></h6>
                  <div class="mb-2">
                    <% review.rating.times do %>
                      <i class="bi bi-star-fill text-warning"></i>
                    <% end %>
                    <% (5 - review.rating).times do %>
                      <i class="bi bi-star text-muted"></i>
                    <% end %>
                  </div>
                </div>
                <small class="text-muted">
                  by <%= review.user.first_name %> • <%= review.created_at.strftime("%B %d, %Y") %>
                  <% if review.verified_purchase? %>
                    <span class="badge bg-success ms-1">Verified Purchase</span>
                  <% end %>
                </small>
              </div>
              <p class="mb-0"><%= review.comment %></p>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-chat-square-text display-4 text-muted"></i>
          <h5 class="mt-3">No reviews yet</h5>
          <p class="text-muted">Be the first to review this product!</p>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Related Products -->
  <% if @related_products.any? %>
    <div class="row mt-5">
      <div class="col-12">
        <h3 class="mb-4">Other cases for <%= @product.iphone_model %></h3>
        <div class="row">
          <% @related_products.each do |product| %>
            <div class="col-md-3 mb-4">
              <%= render 'shared/product_card', product: product %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>