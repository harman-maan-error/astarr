<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Astarr Admin Dashboard</title>
    
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    
    <style>
      .sidebar {
        min-height: 100vh;
        background: #343a40;
      }
      .sidebar .nav-link {
        color: rgba(255,255,255,.75);
      }
      .sidebar .nav-link:hover {
        color: white;
      }
      .sidebar .nav-link.active {
        color: white;
        background: rgba(255,255,255,.1);
      }
    </style>
  </head>

  <body>
    <div class="container-fluid">
      <div class="row">
        <!-- Sidebar -->
        <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
          <div class="position-sticky pt-3">
            <div class="text-center py-3">
              <h4 class="text-white">
                <i class="bi bi-phone me-2"></i>Astarr Admin
              </h4>
            </div>
            
            <ul class="nav flex-column">
              <li class="nav-item">
                <%= link_to admin_root_path, class: "nav-link #{'active' if current_page?(admin_root_path)}" do %>
                  <i class="bi bi-speedometer2 me-2"></i>Dashboard
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_products_path, class: "nav-link #{'active' if controller_name == 'products'}" do %>
                  <i class="bi bi-box me-2"></i>Products
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_categories_path, class: "nav-link #{'active' if controller_name == 'categories'}" do %>
                  <i class="bi bi-tags me-2"></i>Categories
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_pages_path, class: "nav-link #{'active' if controller_name == 'pages'}" do %>
                  <i class="bi bi-file-text me-2"></i>Pages
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_orders_path, class: "nav-link #{'active' if controller_name == 'orders'}" do %>
                  <i class="bi bi-bag me-2"></i>Orders
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_customers_path, class: "nav-link #{'active' if controller_name == 'customers'}" do %>
                  <i class="bi bi-people me-2"></i>Customers
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to admin_reviews_path, class: "nav-link #{'active' if controller_name == 'reviews'}" do %>
                  <i class="bi bi-star me-2"></i>Reviews
                <% end %>
              </li>
            </ul>
            
            <hr class="text-white">
            
            <ul class="nav flex-column">
              <li class="nav-item">
                <%= link_to root_path, class: "nav-link" do %>
                  <i class="bi bi-arrow-left me-2"></i>Back to Store
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to logout_path, method: :delete, class: "nav-link", data: { "turbo-method": :delete } do %>
                  <i class="bi bi-box-arrow-right me-2"></i>Logout
                <% end %>
              </li>
            </ul>
          </div>
        </nav>
        
        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
          <div class="pt-3">
            <%= render 'shared/flash_messages' %>
            <%= yield %>
          </div>
        </main>
      </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
