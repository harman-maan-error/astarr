<div class="card h-100 shadow-sm product-card">
  <% if product.primary_image&.image&.attached? %>
    <%= image_tag product.primary_image.image, class: "card-img-top", style: "height: 250px; object-fit: cover;" %>
  <% else %>
    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
      <i class="bi bi-phone display-4 text-muted"></i>
    </div>
  <% end %>
  
  <div class="card-body d-flex flex-column">
    <div class="d-flex justify-content-between align-items-start mb-2">
      <h6 class="card-title mb-0"><%= product.name %></h6>
      <% if product.category.is_premium? %>
        <span class="badge bg-warning text-dark">Premium</span>
      <% end %>
    </div>
    
    <p class="text-muted small mb-2"><%= product.iphone_model %> • <%= product.color %></p>
    
    <div class="d-flex align-items-center mb-2">
      <% if product.average_rating.present? && product.average_rating > 0 %>
        <div class="me-2">
          <% 5.times do |i| %>
            <% if i < product.average_rating.floor %>
              <i class="bi bi-star-fill text-warning"></i>
            <% elsif i < product.average_rating %>
              <i class="bi bi-star-half text-warning"></i>
            <% else %>
              <i class="bi bi-star text-muted"></i>
            <% end %>
          <% end %>
        </div>
        <small class="text-muted">(<%= product.reviews_count || 0 %>)</small>
      <% else %>
        <small class="text-muted">No reviews yet</small>
      <% end %>
    </div>
    
    <div class="mt-auto">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <% if product.is_on_sale? && product.sale_price.present? %>
            <span class="text-decoration-line-through text-muted">$<%= sprintf("%.2f", product.calculated_price) %></span>
            <span class="fw-bold text-danger">$<%= sprintf("%.2f", product.sale_price) %></span>
          <% else %>
            <span class="fw-bold">$<%= sprintf("%.2f", product.current_price) %></span>
          <% end %>
        </div>
        <% if product.is_on_sale? %>
          <span class="badge bg-danger">Sale</span>
        <% end %>
      </div>
      
      <div class="d-grid gap-2">
        <%= link_to "View Details", product, class: "btn btn-outline-primary btn-sm" %>
        <% if product.in_stock? %>
          <%= form_with url: add_to_cart_path(product), method: :post, local: true, class: "d-grid" do |f| %>
            <%= f.hidden_field :quantity, value: 1 %>
            <%= f.submit "Add to Cart", class: "btn btn-primary btn-sm" %>
          <% end %>
        <% else %>
          <button class="btn btn-secondary btn-sm" disabled>Out of Stock</button>
        <% end %>
      </div>
    </div>
  </div>
</div>