<% content_for :title, "Search Results" %>

<div class="container py-4">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item active">Search Results</li>
    </ol>
  </nav>
  
  <!-- Search Header -->
  <div class="row mb-4">
    <div class="col-12">
      <% if @query.present? %>
        <h1>Search Results for "<%= @query %>"</h1>
        <% if @products.any? %>
          <p class="text-muted">Found <%= @products.count %> products</p>
        <% else %>
          <p class="text-muted">No products found</p>
        <% end %>
      <% else %>
        <h1>Search Products</h1>
        <p class="text-muted">Enter a search term to find iPhone cases</p>
      <% end %>
    </div>
  </div>
  
  <!-- Search Form -->
  <div class="row mb-4">
    <div class="col-lg-6">
      <div class="card">
        <div class="card-body">
          <%= form_with url: search_path, method: :get, local: true, class: "d-flex" do |f| %>
            <%= f.text_field :q, placeholder: "Search for iPhone cases...", class: "form-control me-2", value: @query %>
            <%= f.submit "Search", class: "btn btn-primary" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Search Results -->
  <% if @query.present? %>
    <% if @products.any? %>
      <div class="row">
        <% @products.each do |product| %>
          <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
            <%= render 'shared/product_card', product: product %>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- No Results -->
      <div class="text-center py-5">
        <i class="bi bi-search display-1 text-muted"></i>
        <h3 class="mt-3">No products found</h3>
        <p class="text-muted">
          We couldn't find any products matching "<%= @query %>". 
          <br>Try different keywords or browse our categories.
        </p>
        <div class="mt-4">
          <%= link_to "Browse All Products", products_path, class: "btn btn-primary me-2" %>
          <%= link_to "Astarr Regular", products_path(category: 'astarr'), class: "btn btn-outline-primary me-2" %>
          <%= link_to "Astarr Premium", products_path(category: 'astarr-premium'), class: "btn btn-outline-warning" %>
        </div>
      </div>
    <% end %>
  <% else %>
    <!-- Search Suggestions -->
    <div class="row">
      <div class="col-lg-8">
        <h4>Popular Searches</h4>
        <div class="d-flex flex-wrap gap-2 mb-4">
          <% ['iPhone 15 Pro Max', 'iPhone 15 Pro', 'iPhone 14 Pro', 'Silicone Case', 'Clear Case', 'Leather Case'].each do |suggestion| %>
            <%= link_to suggestion, search_path(q: suggestion), class: "btn btn-outline-secondary btn-sm" %>
          <% end %>
        </div>
        
        <h4>Browse by Category</h4>
        <div class="row">
          <div class="col-md-6 mb-3">
            <div class="card">
              <div class="card-body">
                <h5 class="card-title">Astarr Regular</h5>
                <p class="card-text text-muted">Premium quality cases at great prices</p>
                <%= link_to "Browse Regular", products_path(category: 'astarr'), class: "btn btn-primary" %>
              </div>
            </div>
          </div>
          <div class="col-md-6 mb-3">
            <div class="card border-warning">
              <div class="card-body">
                <h5 class="card-title text-warning">Astarr Premium</h5>
                <p class="card-text text-muted">Luxury cases with premium materials</p>
                <%= link_to "Browse Premium", products_path(category: 'astarr-premium'), class: "btn btn-warning" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>