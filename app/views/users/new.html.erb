<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl w-full space-y-8">
    <div>
      <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
        Create your account
      </h2>
      <p class="mt-2 text-center text-sm text-gray-600">
        Join Astarr and start shopping for premium phone cases
      </p>
    </div>
    
    <%= form_with model: @user, url: signup_path, local: true, class: "mt-8 space-y-8" do |f| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <div class="flex">
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">
                Please fix the following errors:
              </h3>
              <div class="mt-2 text-sm text-red-700">
                <ul class="list-disc pl-5 space-y-1">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Personal Information Section -->
      <div class="bg-white p-6 rounded-lg shadow-sm border">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Personal Information</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :first_name, "First Name *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :first_name, 
                class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                placeholder: "First name",
                required: true %>
          </div>
          
          <div>
            <%= f.label :last_name, "Last Name *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :last_name, 
                class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                placeholder: "Last name",
                required: true %>
          </div>

          <div>
            <%= f.label :email, "Email Address *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.email_field :email, 
                class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                placeholder: "Email address",
                required: true %>
          </div>

          <div>
            <%= f.label :phone, "Phone Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.telephone_field :phone, 
                class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                placeholder: "Phone number" %>
          </div>

          <div>
            <%= f.label :password, "Password *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.password_field :password, 
                class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                placeholder: "Password",
                required: true %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirm Password *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.password_field :password_confirmation, 
                class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                placeholder: "Confirm password",
                required: true %>
          </div>
        </div>
      </div>

      <!-- Shipping Address Section -->
      <div class="bg-white p-6 rounded-lg shadow-sm border">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Shipping Address</h3>
        
        <%= f.fields_for :addresses, @user.addresses.build do |address_form| %>
          <%= address_form.hidden_field :is_default, value: true %>
          
          <div class="grid grid-cols-1 gap-4">
            <div>
              <%= address_form.label :street_address, "Street Address *", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= address_form.text_field :street_address, 
                  class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                  placeholder: "123 Main Street",
                  required: true %>
            </div>



            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <%= address_form.label :city, "City *", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= address_form.text_field :city, 
                    class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                    placeholder: "City",
                    required: true %>
              </div>

              <div>
                <%= address_form.label :province, "Province/State *", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= address_form.select :province, 
                    options_for_select([
                      ['Alberta', 'AB'], ['British Columbia', 'BC'], ['Manitoba', 'MB'],
                      ['New Brunswick', 'NB'], ['Newfoundland and Labrador', 'NL'],
                      ['Northwest Territories', 'NT'], ['Nova Scotia', 'NS'], ['Nunavut', 'NU'],
                      ['Ontario', 'ON'], ['Prince Edward Island', 'PE'], ['Quebec', 'QC'],
                      ['Saskatchewan', 'SK'], ['Yukon', 'YT'],
                      # US States
                      ['Alabama', 'AL'], ['Alaska', 'AK'], ['Arizona', 'AZ'], ['Arkansas', 'AR'],
                      ['California', 'CA'], ['Colorado', 'CO'], ['Connecticut', 'CT'], ['Delaware', 'DE'],
                      ['Florida', 'FL'], ['Georgia', 'GA'], ['Hawaii', 'HI'], ['Idaho', 'ID'],
                      ['Illinois', 'IL'], ['Indiana', 'IN'], ['Iowa', 'IA'], ['Kansas', 'KS'],
                      ['Kentucky', 'KY'], ['Louisiana', 'LA'], ['Maine', 'ME'], ['Maryland', 'MD'],
                      ['Massachusetts', 'MA'], ['Michigan', 'MI'], ['Minnesota', 'MN'], ['Mississippi', 'MS'],
                      ['Missouri', 'MO'], ['Montana', 'MT'], ['Nebraska', 'NE'], ['Nevada', 'NV'],
                      ['New Hampshire', 'NH'], ['New Jersey', 'NJ'], ['New Mexico', 'NM'], ['New York', 'NY'],
                      ['North Carolina', 'NC'], ['North Dakota', 'ND'], ['Ohio', 'OH'], ['Oklahoma', 'OK'],
                      ['Oregon', 'OR'], ['Pennsylvania', 'PA'], ['Rhode Island', 'RI'], ['South Carolina', 'SC'],
                      ['South Dakota', 'SD'], ['Tennessee', 'TN'], ['Texas', 'TX'], ['Utah', 'UT'],
                      ['Vermont', 'VT'], ['Virginia', 'VA'], ['Washington', 'WA'], ['West Virginia', 'WV'],
                      ['Wisconsin', 'WI'], ['Wyoming', 'WY']
                    ], 'MB'), 
                    { prompt: 'Select Province/State' },
                    { class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", required: true } %>
              </div>

              <div>
                <%= address_form.label :postal_code, "Postal Code *", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= address_form.text_field :postal_code, 
                    class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm",
                    placeholder: "R3C 0A5",
                    required: true %>
              </div>
            </div>

            <div>
              <%= address_form.label :country, "Country *", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= address_form.select :country, 
                  options_for_select([['Canada', 'CA'], ['United States', 'US']], 'CA'),
                  {},
                  { class: "appearance-none relative block w-full px-3 py-2 border border-gray-300 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", required: true } %>
            </div>
          </div>
        <% end %>
      </div>

      <div>
        <%= f.submit "Create Account", 
            class: "group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out cursor-pointer" %>
      </div>

      <div class="text-center">
        <p class="text-sm text-gray-600">
          Already have an account?
          <%= link_to "Sign in here", login_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
        </p>
      </div>
    <% end %>
  </div>
</div>